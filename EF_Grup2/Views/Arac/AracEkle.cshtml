@model EF_Grup2.Models.Arac

@{
	ViewData["Title"] = "Araç Ekle";
}

<div class="container mt-4">
	<div class="card shadow">
		<div class="card-header bg-primary text-white">
			<h4>Araç Bilgisi</h4>
		</div>
		<div class="card-body">

			<form asp-action="AracEkle" method="post" enctype="multipart/form-data" >

				<div class="row">
					<div class="col-md-6 mb-3">
						<label asp-for="Marka" class="form-label"></label>
						<input asp-for="Marka" class="form-control" placeholder="Marka giriniz" />
						<span asp-validation-for="Marka" class="text-danger"></span>
					</div>

					<div class="col-md-6 mb-3">
						<label asp-for="Plaka" class="form-label"></label>
						<input asp-for="Plaka" class="form-control" placeholder="Plaka giriniz" />
						<span asp-validation-for="Plaka" class="text-danger"></span>
					</div>
				</div>

				<div class="row">
					<div class="col-md-6 mb-3">
						<label asp-for="ModelYili" class="form-label"></label>
						<input asp-for="ModelYili" class="form-control" type="number" />
						<span asp-validation-for="ModelYili" class="text-danger"></span>
					</div>

					<div class="col-md-6 mb-3">
						<label asp-for="Fiyat" class="form-label"></label>
						<input asp-for="Fiyat" class="form-control" type="number" step="0.01" />
						<span asp-validation-for="Fiyat" class="text-danger"></span>
					</div>
				</div>  
				<div class="row">
					<div class="col-md-6 mb-3">
						<label asp-for="ResimYolu" class="form-label"></label>
						<input asp-for="ResimYolu" class="form-control" type="file"   />
						<span asp-validation-for="Fiyat" class="text-danger"></span>
					</div>
				</div>
				<div class="d-flex justify-content-end">
					<a asp-action="Index" class="btn btn-secondary me-2">Geri</a>
					<button type="submit" class="btn btn-success">Kaydet</button>
				</div>







			</form>

		</div>
	</div>
</div>