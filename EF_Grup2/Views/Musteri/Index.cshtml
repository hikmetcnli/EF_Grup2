@model IEnumerable<EF_Grup2.Models.Musteri>

@{
    ViewData["Title"] = "Müşteri Listesi";
}

<h2>Müşteri Listesi</h2>

<a asp-action="MusteriEkle" class="btn btn-success mb-3">Yeni Müşteri Ekle</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Ad</th>
            <th>Soyad</th>
            <th>Adres</th>
            <th>Telefon</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Adi</td>
                <td>@item.Soyadi</td>
                <td>@item.Adres</td>
                <td>@item.Telefon</td>
                <td>
                    <a asp-action="MusteriEkle" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                    <a asp-action="MusteriSil" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>