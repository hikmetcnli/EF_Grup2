@model EF_Grup2.Models.Musteri

@{
    ViewData["Title"] = "Müşteri Ekle";
}

<h2>Müşteri Formu</h2>

<form asp-controller="Musteri" asp-action="MusteriEkle" method="post" class="mt-4">
    <div class="form-group mb-3">
        <label asp-for="Adi" class="form-label"></label>
        <input asp-for="Adi" class="form-control" placeholder="Ad giriniz" />
        <span asp-validation-for="Adi" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Soyadi" class="form-label"></label>
        <input asp-for="Soyadi" class="form-control" placeholder="Soyad giriniz" />
        <span asp-validation-for="Soyadi" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Adres" class="form-label"></label>
        <textarea asp-for="Adres" class="form-control" rows="3" placeholder="Adres giriniz"></textarea>
        <span asp-validation-for="Adres" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Telefon" class="form-label"></label>
        <input asp-for="Telefon" class="form-control" placeholder="Telefon giriniz" />
        <span asp-validation-for="Telefon" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a asp-action="Index" class="btn btn-secondary">Geri Dön</a>
</form>